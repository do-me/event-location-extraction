      "cli_server": "mlx_lm.server --model REPO_ID --port 8080"
    },
    "notes": {
      "structured_output": "Qwen3.5 models support structured output / JSON mode via system prompts and chat templates. Use 'Respond in JSON format' in system prompt or set response_format={'type':'json_object'} when using via API server.",
